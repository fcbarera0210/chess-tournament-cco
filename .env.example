# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-random-32-char-string

# Seed script: first admin user (run npm run db:seed once)
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-me

# Optional: tournament slug for single-tournament v1 (default: curico-2026)
PUBLIC_TOURNAMENT_SLUG=curico-2026
