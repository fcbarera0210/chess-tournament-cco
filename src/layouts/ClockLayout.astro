---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Reloj de ajedrez' } = Astro.props;
---

<!doctype html>
<html lang="es" class="min-h-dvh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta
      name="description"
      content="Reloj de ajedrez digital gratuito. Presets 10+5, 5+3 y personalizable. Funciona sin conexión después de la primera carga."
    />
    <meta name="theme-color" content="#141414" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh bg-dark text-white">
    <main class="mx-auto min-h-dvh w-full max-w-7xl px-4 py-4 md:px-6 md:py-6">
      <slot />
    </main>
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
