---
import '../styles/global.css';
import SiteFooter from '../components/astro/SiteFooter.astro';
import FloatingPiecesBackground from '../components/astro/FloatingPiecesBackground.astro';
import { MobileNav } from '../components/react/MobileNav';
import { SITE_BRAND } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  kiosk?: boolean;
  dark?: boolean;
  finished?: boolean;
  tournamentSlug?: string | null;
  tournamentName?: string;
  showRegistration?: boolean;
}

const {
  title,
  description,
  wide = false,
  kiosk = false,
  dark = false,
  finished = false,
  tournamentSlug = null,
  tournamentName = 'Chess Tournament Curicó',
  showRegistration = false,
} = Astro.props;

const pageTitle = title ?? tournamentName;
const pageDescription =
  description ??
  (finished
    ? 'Archivo del torneo de ajedrez en Curicó. Clasificación, partidas y galería del evento realizado.'
    : 'Torneo de ajedrez abierto en Curicó. Inscripción gratuita.');
---

<!doctype html>
<html lang="es" class="min-h-dvh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="view-transition" content="same-origin" />
  </head>
  <body
    class:list={[
      !kiosk && 'flex flex-col',
      kiosk ? 'bg-bg text-ink' : dark ? 'bg-dark text-white' : 'bg-bg text-ink',
      !kiosk ? 'min-h-dvh' : 'min-h-screen',
    ]}
  >
    <FloatingPiecesBackground />
    {
      !kiosk && (
        <header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur">
          <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
            <a href="/" class="flex items-center gap-2.5 font-display text-lg font-bold text-ink">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-ink text-sm text-white">
                ♞
              </span>
              {SITE_BRAND}
            </a>
            <div class="flex items-center gap-4 text-sm font-medium">
              <div class="hidden items-center gap-4 sm:flex">
                {
                  tournamentSlug ? (
                    finished ? (
                      <>
                        <a href={`/torneo/${tournamentSlug}`} class="text-muted hover:text-ink">
                          Resultados
                        </a>
                        <a href={`/clasificacion/${tournamentSlug}`} class="text-muted hover:text-ink">
                          Clasificación
                        </a>
                      </>
                    ) : (
                      <>
                        <a href={`/clasificacion/${tournamentSlug}`} class="text-muted hover:text-ink">
                          Clasificación
                        </a>
                        <a href={`/live/${tournamentSlug}`} class="text-muted hover:text-ink">
                          Live
                        </a>
                        <a href="/reloj" class="text-muted hover:text-ink">
                          Reloj
                        </a>
                        {showRegistration && (
                          <a
                            href={`/inscripcion/${tournamentSlug}`}
                            class="btn-pill btn-pill-primary px-4 py-2 text-sm"
                          >
                            Inscribirme
                          </a>
                        )}
                      </>
                    )
                  ) : (
                    <>
                      <a href="/bases" class="text-muted hover:text-ink">
                        Bases
                      </a>
                      <a href="/reloj" class="text-muted hover:text-ink">
                        Reloj
                      </a>
                    </>
                  )
                }
              </div>
              <MobileNav
                client:load
                slug={tournamentSlug}
                finished={finished}
                showRegistration={showRegistration}
              />
            </div>
          </nav>
        </header>
      )
    }
    <main
      class:list={[
        'relative z-10 mx-auto w-full',
        !kiosk && 'flex-1',
        wide || kiosk ? 'max-w-7xl' : 'max-w-6xl',
        kiosk ? 'px-4 py-4 md:px-6 md:py-6' : 'px-4 py-8',
      ]}
    >
      <slot />
    </main>
    {
      !kiosk && (
        <SiteFooter
          slug={tournamentSlug}
          finished={finished}
          showRegistration={showRegistration}
        />
      )
    }
  </body>
</html>

<style is:global>
  @view-transition {
    navigation: auto;
  }
</style>
