---
import '../styles/global.css';
import SiteFooter from '../components/astro/SiteFooter.astro';
import FloatingPiecesBackground from '../components/astro/FloatingPiecesBackground.astro';
import { MobileNav } from '../components/react/MobileNav';
import { getActiveTournament } from '../lib/tournament';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  kiosk?: boolean;
  dark?: boolean;
  finished?: boolean;
}

const tournament = await getActiveTournament();
const tournamentName = tournament?.name ?? 'Chess Tournament Curicó';
const isFinished = Astro.props.finished ?? tournament?.status === 'finished';

const {
  title = tournamentName,
  description = isFinished
    ? 'Archivo del torneo de ajedrez en Curicó. Clasificación, partidas y galería del evento realizado.'
    : 'Torneo de ajedrez abierto en Curicó. Inscripción gratuita.',
  wide = false,
  kiosk = false,
  dark = false,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="min-h-dvh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="view-transition" content="same-origin" />
  </head>
  <body
    class:list={[
      !kiosk && 'flex flex-col',
      kiosk ? 'bg-bg text-ink' : dark ? 'bg-dark text-white' : 'bg-bg text-ink',
      !kiosk ? 'min-h-dvh' : 'min-h-screen',
    ]}
  >
    <FloatingPiecesBackground />
    {
      !kiosk && (
        <header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur">
          <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
            <a href="/" class="flex items-center gap-2.5 font-display text-lg font-bold text-ink">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-ink text-sm text-white">
                ♞
              </span>
              {tournamentName}
            </a>
            <div class="flex items-center gap-4 text-sm font-medium">
              <div class="hidden items-center gap-4 sm:flex">
                {
                  isFinished ? (
                    <>
                      <a href="/torneo" class="text-muted hover:text-ink">
                        Resultados
                      </a>
                      <a href="/clasificacion" class="text-muted hover:text-ink">
                        Clasificación
                      </a>
                    </>
                  ) : (
                    <>
                      <a href="/clasificacion" class="text-muted hover:text-ink">
                        Clasificación
                      </a>
                      <a href="/live" class="text-muted hover:text-ink">
                        Live
                      </a>
                      <a href="/inscripcion" class="btn-pill btn-pill-primary px-4 py-2 text-sm">
                        Inscribirme
                      </a>
                    </>
                  )
                }
              </div>
              <MobileNav client:load finished={isFinished} />
            </div>
          </nav>
        </header>
      )
    }
    <main
      class:list={[
        'relative z-10 mx-auto w-full',
        !kiosk && 'flex-1',
        wide || kiosk ? 'max-w-7xl' : 'max-w-6xl',
        kiosk ? 'px-4 py-4 md:px-6 md:py-6' : 'px-4 py-8',
      ]}
    >
      <slot />
    </main>
    {!kiosk && <SiteFooter tournamentName={tournamentName} finished={isFinished} />}
  </body>
</html>

<style is:global>
  @view-transition {
    navigation: auto;
  }
</style>
