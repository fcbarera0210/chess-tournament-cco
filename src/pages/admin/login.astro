---
import '../../styles/global.css';
import { AdminLoginForm } from '../../components/react/AdminLoginForm';
import { CHESS_SVG_SIZE } from '../../lib/chess-svg-sizes';

export const prerender = false;

const authError = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>Acceso admin — Chess Tournament Curicó</title>
  </head>
  <body class="min-h-screen bg-bg text-ink">
    <main class="mx-auto flex min-h-screen max-w-5xl items-center px-4 py-12">
      <div class="w-full overflow-hidden rounded-3xl shadow-xl lg:grid lg:grid-cols-2">
        <div class="section-dark relative flex flex-col justify-between p-8 md:p-12">
          <div>
            <a href="/" class="text-sm text-white/60 hover:text-white">← Volver al sitio</a>
            <h1 class="font-display mt-8 text-3xl font-bold md:text-4xl">Organización</h1>
            <p class="mt-3 text-white/70">Panel de control del torneo · acceso restringido</p>
          </div>
          <div class="mt-12 flex items-end justify-center gap-6 px-2 sm:gap-10">
            <img
              src="/images/chess/w-king.svg"
              alt=""
              width={CHESS_SVG_SIZE['w-king'].width}
              height={CHESS_SVG_SIZE['w-king'].height}
              loading="lazy"
              class="h-16 w-auto shrink-0"
              aria-hidden="true"
            />
            <img
              src="/images/chess/b-pawn.svg"
              alt=""
              width={CHESS_SVG_SIZE['b-pawn'].width}
              height={CHESS_SVG_SIZE['b-pawn'].height}
              loading="lazy"
              class="h-12 w-auto shrink-0 opacity-90"
              aria-hidden="true"
            />
            <img
              src="/images/chess/w-queen.svg"
              alt=""
              width={CHESS_SVG_SIZE['w-queen'].width}
              height={CHESS_SVG_SIZE['w-queen'].height}
              loading="lazy"
              class="h-20 w-auto shrink-0"
              aria-hidden="true"
            />
          </div>
        </div>

        <div class="bg-surface p-8 md:p-12">
          <AdminLoginForm client:load authError={authError} />
        </div>
      </div>
    </main>
  </body>
</html>
