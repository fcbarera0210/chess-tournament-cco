---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const csrfRes = await fetch(new URL('/api/auth/csrf', Astro.url.origin), {
  headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
});
const { csrfToken } = await csrfRes.json();
---

<BaseLayout title="Admin Login">
  <div class="py-12">
    <form
      method="post"
      action="/api/auth/callback/credentials"
      class="mx-auto max-w-sm space-y-4 rounded-2xl border border-sand bg-white p-6 shadow-sm"
    >
      <h1 class="font-display text-xl font-bold text-teal">Acceso organización</h1>
      <input type="hidden" name="csrfToken" value={csrfToken} />
      <input type="hidden" name="callbackUrl" value="/admin" />
      <div>
        <label class="mb-1 block text-sm font-medium" for="username">Usuario</label>
        <input
          id="username"
          name="username"
          type="text"
          required
          class="w-full rounded-xl border border-sand px-4 py-2.5 focus:border-teal focus:outline-none"
        />
      </div>
      <div>
        <label class="mb-1 block text-sm font-medium" for="password">Contraseña</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          class="w-full rounded-xl border border-sand px-4 py-2.5 focus:border-teal focus:outline-none"
        />
      </div>
      <button
        type="submit"
        class="w-full rounded-xl bg-teal py-3 font-semibold text-white hover:bg-teal-light"
      >
        Entrar
      </button>
    </form>
  </div>
</BaseLayout>
