---
import BaseLayout from '../layouts/BaseLayout.astro';
import PillButton from '../components/astro/PillButton.astro';
import ChessPiece from '../components/astro/ChessPiece.astro';
import { loadHomePageData } from '../lib/home-page';

const { navTournament } = await loadHomePageData();
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe o ya no está disponible."
  tournamentSlug={navTournament?.slug ?? null}
  tournamentName={navTournament?.name ?? 'Chess Tournament Curicó'}
  showRegistration={false}
  finished={navTournament?.status === 'finished'}
>
  <div class="mx-auto max-w-2xl overflow-hidden rounded-3xl shadow-xl">
    <div class="section-dark relative px-8 py-14 text-center md:px-12 md:py-16">
      <div class="mb-8 flex items-end justify-center gap-4 sm:gap-8">
        <ChessPiece name="b-king" class="h-14 w-auto opacity-80" />
        <ChessPiece name="w-queen" class="h-20 w-auto" />
        <ChessPiece name="b-pawn" class="h-10 w-auto opacity-70" />
      </div>

      <p class="font-display text-7xl font-bold tracking-tight text-white/90 md:text-8xl">404</p>
      <h1 class="font-display mt-4 text-3xl font-bold md:text-4xl">Jaque mate</h1>
      <p class="mx-auto mt-4 max-w-md text-white/70">
        Esta casilla no existe. La página pudo haberse movido, eliminarse o la URL puede estar
        mal escrita.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <PillButton href="/">Volver al inicio</PillButton>
        {
          navTournament && (
            <PillButton
              href={
                navTournament.status === 'finished'
                  ? `/torneo/${navTournament.slug}`
                  : `/clasificacion/${navTournament.slug}`
              }
              variant="outline-light"
            >
              {navTournament.status === 'finished' ? 'Ver torneo' : 'Ver clasificación'}
            </PillButton>
          )
        }
      </div>
    </div>

    <div class="bg-surface px-8 py-6 text-center text-sm text-muted">
      <a href="/bases" class="font-semibold text-ink underline-offset-2 hover:underline">
        Bases del torneo
      </a>
      <span class="mx-2">·</span>
      <a href="/reloj" class="font-semibold text-ink underline-offset-2 hover:underline">
        Reloj
      </a>
    </div>
  </div>
</BaseLayout>
