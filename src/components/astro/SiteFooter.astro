---
interface Props {
  tournamentName?: string;
}

const { tournamentName = 'Chess Tournament Curicó' } = Astro.props;
---

<footer class="relative z-10 section-dark mt-auto py-12">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex flex-col items-center gap-6 md:flex-row md:justify-between">
      <div class="flex items-center gap-2">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-white text-lg text-ink">♞</span>
        <span class="font-display font-bold">{tournamentName}</span>
      </div>
      <nav class="flex flex-wrap justify-center gap-6 text-sm text-white/70">
        <a href="/inscripcion" class="hover:text-white">Inscripción</a>
        <a href="/clasificacion" class="hover:text-white">Clasificación</a>
        <a href="/bases" class="hover:text-white">Bases</a>
        <a href="/live" class="hover:text-white">Live</a>
        <a href="/kiosk" class="hover:text-white">Kiosk</a>
      </nav>
    </div>
    <p class="mt-8 text-center text-xs text-white/40">
      Página hecha con cariño por
      <a
        href="https://charlideas.vercel.app/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-white/60 underline-offset-2 hover:text-white hover:underline"
      >
        charl!deas
      </a>
      🤍🖤
    </p>
  </div>
</footer>
