---
import PillButton from './PillButton.astro';
import SpotsBadge from './SpotsBadge.astro';
import type { FeaturedSpotsInfo } from '../../lib/home-page';

interface Props {
  tournamentName?: string;
  slug?: string;
  finished?: boolean;
  showRegistration?: boolean;
  eventDate?: string;
  venue?: string;
  spotsInfo?: FeaturedSpotsInfo | null;
}

const {
  tournamentName = 'Chess Tournament Curicó',
  slug = '',
  finished = false,
  showRegistration = false,
  eventDate = '',
  venue = '',
  spotsInfo = null,
} = Astro.props;
---

<section class="hero-texture relative overflow-hidden rounded-3xl px-6 py-20 md:px-12 md:py-28">
  <div class="relative z-10 mx-auto max-w-3xl text-center">
    <h1 class="font-display text-4xl font-extrabold leading-tight tracking-tight md:text-6xl lg:text-7xl">
      {tournamentName}
    </h1>
    {
      finished ? (
        <>
          <span class="mt-6 inline-flex rounded-full border border-finished/30 bg-finished/10 px-4 py-1.5 text-sm font-semibold text-finished">
            Torneo finalizado
          </span>
          <p class="mx-auto mt-6 max-w-xl text-lg text-muted md:text-xl">
            Gracias a todos los que participaron. Revisa la clasificación, las partidas y las fotos del
            evento.
          </p>
          {eventDate && (
            <p class="mx-auto mt-3 max-w-xl capitalize text-muted">
              {eventDate}
              {venue ? ` · ${venue}` : ''}
            </p>
          )}
          {slug && (
            <div class="mt-8 flex flex-wrap justify-center gap-4">
              <PillButton href={`/torneo/${slug}`}>Ver resultados del torneo</PillButton>
              <PillButton href={`/clasificacion/${slug}`} variant="outline">Clasificación</PillButton>
            </div>
          )}
        </>
      ) : (
        <>
          <p class="mx-auto mt-6 max-w-xl text-lg text-muted md:text-xl">
            Torneo casual de ajedrez. Inscripción gratuita, todos los niveles bienvenidos.
          </p>
          {slug && showRegistration && (
            <div class="mt-8 flex justify-center">
              <SpotsBadge spotsInfo={spotsInfo} />
            </div>
          )}
          {slug && (
            <div class="mt-8 flex flex-wrap justify-center gap-4">
              {showRegistration && (
                <PillButton href={`/inscripcion/${slug}`}>Inscribirme</PillButton>
              )}
              <PillButton href={`/clasificacion/${slug}`} variant="outline">Clasificación</PillButton>
            </div>
          )}
        </>
      )
    }
  </div>
</section>
