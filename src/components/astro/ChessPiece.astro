---
import { CHESS_SVG_SIZE, CHESS_SPRITE_URL, isSpritePiece, type ChessSvgName } from '../../lib/chess-svg-sizes';

interface Props {
  name: ChessSvgName;
  class?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'auto' | 'sync';
}

const { name, class: className = '', loading, decoding = 'async' } = Astro.props;
const size = CHESS_SVG_SIZE[name];
const useSprite = isSpritePiece(name);
---

{
  useSprite ? (
    <svg
      width={size.width}
      height={size.height}
      class={className}
      aria-hidden="true"
      focusable="false"
    >
      <use href={`${CHESS_SPRITE_URL}#${name}`} />
    </svg>
  ) : (
    <img
      src={`/images/chess/${name}.svg`}
      alt=""
      width={size.width}
      height={size.height}
      loading={loading}
      decoding={decoding}
      class={className}
      aria-hidden="true"
    />
  )
}
