---
import { CHESS_SVG_SIZE, chessSvgSrc, type ChessSvgName } from '../../lib/chess-svg-sizes';

interface Props {
  name: ChessSvgName;
  class?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'auto' | 'sync';
}

const { name, class: className = '', loading, decoding = 'async' } = Astro.props;
const size = CHESS_SVG_SIZE[name];
---

<img
  src={chessSvgSrc(name)}
  alt=""
  width={size.width}
  height={size.height}
  loading={loading}
  decoding={decoding}
  class={className}
  aria-hidden="true"
/>
