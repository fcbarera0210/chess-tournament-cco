---
import ChessPiece from './ChessPiece.astro';
import type { ChessSvgName } from '../../lib/chess-svg-sizes';

interface Props {
  number: string;
  title: string;
  variant?: 'light' | 'dark';
  desktopVariant?: 'light' | 'dark';
  piece?: ChessSvgName;
  desktopPiece?: ChessSvgName;
  image?: string;
  desktopImage?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  desktopImageWidth?: number;
  desktopImageHeight?: number;
}

const {
  number,
  title,
  variant = 'light',
  desktopVariant,
  piece,
  desktopPiece,
  image,
  desktopImage,
  imageAlt = '',
  imageWidth,
  imageHeight,
  desktopImageWidth,
  desktopImageHeight,
} = Astro.props;

const mobileDark = variant === 'dark';
const responsiveSurface = desktopVariant != null;

const surfaceClasses = responsiveSurface
  ? mobileDark
    ? 'bg-[var(--color-dark-card)] text-white sm:bg-[var(--color-surface)] sm:text-[var(--color-ink)]'
    : 'bg-[var(--color-surface)] text-[var(--color-ink)] sm:bg-[var(--color-dark-card)] sm:text-white'
  : mobileDark
    ? 'card-dark'
    : 'card-light';

const pieceClass =
  'pointer-events-none absolute top-0 right-0 bottom-0 h-full w-auto max-w-[45%] object-contain object-right opacity-90';
---

<div
  class:list={[
    'relative flex min-h-[200px] flex-col overflow-hidden rounded-3xl p-6 md:min-h-[240px] md:p-8',
    surfaceClasses,
  ]}
>
  <div class="relative flex min-h-0 flex-1 flex-col justify-between">
    {
      piece ? (
        <ChessPiece
          name={piece}
          class:list={[pieceClass, desktopPiece && 'sm:hidden']}
        />
      ) : (
        image && (
          <img
            src={image}
            alt={imageAlt}
            width={imageWidth ?? 22}
            height={imageHeight ?? 62}
            loading="lazy"
            decoding="async"
            class:list={[pieceClass, desktopImage && 'sm:hidden']}
          />
        )
      )
    }
    {
      desktopPiece ? (
        <ChessPiece name={desktopPiece} class:list={[pieceClass, 'hidden sm:block']} />
      ) : (
        desktopImage && (
          <img
            src={desktopImage}
            alt={imageAlt}
            width={desktopImageWidth ?? imageWidth ?? 22}
            height={desktopImageHeight ?? imageHeight ?? 62}
            loading="lazy"
            decoding="async"
            class="pointer-events-none absolute top-0 right-0 bottom-0 hidden h-full w-auto max-w-[45%] object-contain object-right opacity-90 sm:block"
          />
        )
      )
    }
    <span class="relative z-10 num-badge w-fit">{number}</span>
    <p class="relative z-10 max-w-[80%] text-xl font-bold leading-snug md:text-2xl">
      {title}
    </p>
  </div>
  <slot />
</div>
